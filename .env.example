# Collectables — example environment file
#
# Copy to `.env` and fill in real values. Never commit `.env`.
# These EXPO_PUBLIC_* names must match exactly what `README-DEPLOY.md`
# lists, because Metro/babel only inlines literal `process.env.NAME`
# accesses; renaming on either side silently breaks the web bundle.

# Supabase (required for auth + cloud sync)
EXPO_PUBLIC_SUPABASE_URL=paste your project URL
EXPO_PUBLIC_SUPABASE_PUBLISHABLE_KEY=paste your publishable (anon) key

# Runtime Supabase config override (optional). LEAVE UNSET for production.
# Set to the literal `true` ONLY on a QA/preview deploy to let the app read its
# Supabase URL/key from localStorage over the build-time secrets. Off by default
# (always on in __DEV__) — SEC-4 closes the account-takeover vector where XSS or
# a malicious extension could repoint a production build at an attacker project.
EXPO_PUBLIC_ALLOW_RUNTIME_SUPABASE_CONFIG=

# Cloudinary (optional — falls back to the bundled defaults when empty)
EXPO_PUBLIC_CLOUDINARY_URL=
EXPO_PUBLIC_CLOUDINARY_CLOUD_NAME=
EXPO_PUBLIC_CLOUDINARY_UPLOAD_PRESET=

# Sentry (optional — when empty, the SDK skips init and captureException is a no-op)
EXPO_PUBLIC_SENTRY_DSN=
# One of development | staging | production. Defaults to production in CI;
# development disables event reporting entirely.
EXPO_PUBLIC_SENTRY_ENV=

# PostHog product analytics (optional — when empty, analytics SDK skips init)
EXPO_PUBLIC_POSTHOG_KEY=
# Defaults to https://eu.posthog.com (EU cloud). Override to https://us.i.posthog.com
# for the US cloud or a self-hosted URL.
EXPO_PUBLIC_POSTHOG_HOST=

# Microsoft Clarity session replay (optional, web-only)
EXPO_PUBLIC_CLARITY_PROJECT_ID=

# Public base URL of the deployed site (optional).
# The deploy workflow pins this so deep links resolve correctly even when
# shared from a sub-route. Local dev usually leaves this empty.
EXPO_PUBLIC_APP_URL=

# Viewer-profile cache TTL in milliseconds (optional).
# Default: 600000 (10 minutes). The social context warns once at runtime when
# the configured value is below 30000 (30 seconds), because aggressive
# overrides hammer Supabase's free-tier rate limits.
EXPO_PUBLIC_PROFILE_CACHE_TTL_MS=

# Realtime WebSocket kill-switch (optional).
# Set to "1", "true", or "yes" to make `getSharedRealtimeClient()` return null
# regardless of whether Supabase is configured. Drops all realtime traffic
# (chat inbox, marketplace updates) without redeploying. Useful for incident
# response and offline-only QA.
EXPO_PUBLIC_REALTIME_DISABLED=

# Analytics kill-switch (optional).
# Set to "1", "true", or "yes" to force-disable PostHog *and* Microsoft Clarity
# regardless of whether their keys are present. Drops all third-party tracking
# without a code change. Useful for incident response (broken analytics SDK or a
# privacy hold).
EXPO_PUBLIC_ANALYTICS_DISABLED=

# Language→currency override (optional).
# Format: `lang:CODE,lang:CODE` (e.g. `ru:RUB,en:EUR`). Each entry replaces the
# bundled default in `lib/locale-helpers.ts` (ru→RUB, be→BYN, de→EUR, pl→PLN,
# es→EUR, en→USD); unmentioned languages keep their canonical currency.
# Currency codes are upper-cased; language codes are lower-cased. Invalid
# tokens (missing colon, non-ISO-4217 shape) are silently dropped so a typo
# never crashes the app. Lets QA flip per-region defaults for localized
# launches without a code change.
EXPO_PUBLIC_LANGUAGE_CURRENCY=
